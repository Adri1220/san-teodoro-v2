---
// La zona de "Frontmatter" de Astro. Aquí va el JS que se ejecuta en el servidor.
// Recibimos el título de la página como propiedad para que cada pestaña cambie su nombre.
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
   <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>{title}</title>

      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@500&family=Public+Sans:wght@400;600&display=swap" rel="stylesheet" />

      <link rel="stylesheet" href="/css/styles.css" />
   </head>
   <body class="grid-container">
      
      <header class="header">
         <div class="header__logo">San Teodoro</div>
         <nav class="header__nav nav">
            <ul class="nav__list">
               <li class="nav__item"><a href="/" class="nav__link">Inicio</a></li>
               <li class="nav__item"><a href="/historia" class="nav__link">Historia</a></li>
               <li class="nav__item"><a href="/colecciones" class="nav__link">Colecciones</a></li>
               <li class="nav__item"><a href="/catalogo" class="nav__link">Catálogo</a></li>
               <li class="nav__item"><a href="/nosotros" class="nav__link">Sobre Nosotros</a></li>
            </ul>
         </nav>
         <div class="header__icon"></div>
      </header>

      <main class="main">
         <slot />
      </main>

      <footer class="footer">
         <div class="footer__container">
            <div class="footer__top">
               <div class="footer__brand">
                  <span class="footer__logo">San Teodoro</span>
                  <p class="footer__text">
                     Prototipo de Repositorio Digital de Arte Funerario.<br />Proyecto de Tesis para la preservación del patrimonio histórico de Piura.
                  </p>
               </div>
               <div class="footer__links-wrapper">
                  <ul class="footer__list">
                     <li><a href="/nosotros" class="footer__link">El Proyecto</a></li>
                     <li><a href="/catalogo" class="footer__link">Catálogo 3D</a></li>
                  </ul>
                  <ul class="footer__list">
                     <li><a href="/investigador" class="footer__link">Investigación</a></li>
                     <li><a href="#" class="footer__link">Contacto</a></li>
                  </ul>
               </div>
            </div>
            <div class="footer__bottom">
               <span class="footer__copy">© 2026 Repositorio San Teodoro. Piura, Perú.</span>
               <div class="footer__legal">
                  <a href="#">Metodología</a>
                  <a href="#">Créditos</a>
               </div>
            </div>
         </div>
      </footer>

      <script src="/js/data.js" is:inline></script>
      <script src="/js/main.js" is:inline></script>
   </body>
</html>