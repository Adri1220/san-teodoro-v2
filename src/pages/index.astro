---
import Layout from './layouts/Layout.astro';
---

<Layout title="Archivo San Teodoro | Inicio">
   <section class="hero" id="inicio">
      <div class="hero__overlay"></div>
      <div class="hero__content">
         <span class="hero__label">REPOSITORIO DE ARTE FUNERARIO</span>
         <h1 class="hero__title">Preservando el Arte de Piura</h1>
         <p class="hero__text">
            Un museo a cielo abierto. Este archivo preserva el valor
            histórico y arquitectónico de los nichos y esculturas del
            Cementerio San Teodoro mediante digitalización por
            fotogrametría.
         </p>
         <div class="hero__actions">
            <a href="/catalogo" class="btn btn--primary">Ver Catálogo 3D</a>
            <a href="/nosotros" class="btn btn--secondary">Sobre el Proyecto</a>
         </div>
      </div>
   </section>
</Layout>