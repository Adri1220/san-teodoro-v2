---
import Layout from './layouts/Layout.astro';
---

<Layout title="Archivo San Teodoro | Nicho Histórico">
   <section class="narrative" style="padding-top: 150px;">
      <div class="narrative__container">
         <a href="/catalogo" class="artwork__back">&larr; VOLVER AL CATÁLOGO</a>

         <div class="narrative__grid">
            <div class="narrative__media">
               <div id="narrative-img-container"></div>
               <div class="thumbnail-gallery" style="display: flex; gap: 8px; margin-top: 16px;"></div>
            </div>

            <div class="narrative__content">
               <!-- Categoría e inyectada por ficha.js -->
               <span class="artwork__category" id="narrative-category"></span>
               <h1 class="narrative__title"></h1>

               <!-- Estado de conservación, inyectado por ficha.js -->
               <div class="artwork__status" style="margin-bottom: 32px;"></div>

               <!-- Metadatos ARCA: los estilos vienen de .meta-item, .meta-label, .meta-value en styles.css -->
               <ul class="artwork__meta" style="list-style: none; padding: 0;">
                  <li class="meta-item">
                     <span class="meta-label">AÑO</span>
                     <span class="meta-value" id="meta-anio"></span>
                  </li>
                  <li class="meta-item">
                     <span class="meta-label">MATERIAL</span>
                     <span class="meta-value" id="meta-material"></span>
                  </li>
                  <li class="meta-item">
                     <span class="meta-label">AUTOR</span>
                     <span class="meta-value" id="meta-autor"></span>
                  </li>
                  <li class="meta-item">
                     <span class="meta-label">UBICACIÓN / SECTOR</span>
                     <span class="meta-value" id="meta-ubicacion"></span>
                  </li>
                  <li class="meta-item">
                     <span class="meta-label">CÓDIGO</span>
                     <span class="meta-value" id="meta-codigo"></span>
                  </li>
                  <li class="meta-item">
                     <span class="meta-label">DIMENSIONES</span>
                     <span class="meta-value" id="meta-dimensiones"></span>
                  </li>
                  <li class="meta-item">
                     <span class="meta-label">ESTILO</span>
                     <span class="meta-value" id="meta-estilo"></span>
                  </li>
                  <li class="meta-item">
                     <span class="meta-label">CARACTERÍSTICAS</span>
                     <span class="meta-value" id="meta-caracteristicas"></span>
                  </li>
               </ul>

               <!-- Plano de ubicación, revelado por ficha.js si datos.imagen_plano existe -->
               <div id="mapa-container" style="margin-bottom: 32px; display: none;">
                  <h4 style="font-family: var(--font-sans); font-size: 12px; color: var(--color-text-muted); margin-bottom: 8px; letter-spacing: 0.1em;">PLANO DE UBICACIÓN</h4>
                  <img id="imagen-mapa" src="" alt="Plano de ubicación" style="width: 100%; border: 1px solid var(--color-border-marble);" />
               </div>

               <!-- Reseña narrativa, inyectada por ficha.js -->
               <div class="narrative__story" id="texto-resena"></div>
            </div>
         </div>
      </div>
   </section>
</Layout>