---
import Layout from './layouts/Layout.astro';
---

<Layout title="Archivo San Teodoro | Ficha Técnica">
   <section class="artwork" style="padding-top: 150px;">
      <div class="artwork__container">
         <a href="/catalogo" class="artwork__back">&larr; VOLVER AL CATÁLOGO</a>

         <div class="artwork__grid">
            <div class="artwork__media">
               <div id="visor3d-container"></div>
               
               <div id="mapa-container" style="margin-top: 24px; display: none;">
                  <h4 style="font-family: var(--font-sans); font-size: 12px; color: var(--color-text-muted); margin-bottom: 8px; letter-spacing: 0.1em;">PLANO DE UBICACIÓN</h4>
                  <img id="imagen-mapa" src="" alt="Plano de ubicación" style="width: 100%; border: 1px solid var(--color-border-marble);" />
               </div>
            </div>

            <div class="artwork__details">
               <span class="artwork__category"></span>
               <h1 class="artwork__title"></h1>

               <div class="artwork__status"></div>

               <ul class="artwork__meta" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px 40px;">
                  <li class="meta-item">
                     <span class="meta-label">AÑO</span>
                     <span class="meta-value" id="meta-anio"></span>
                  </li>
                  <li class="meta-item">
                     <span class="meta-label">MATERIAL</span>
                     <span class="meta-value" id="meta-material"></span>
                  </li>
                  <li class="meta-item">
                     <span class="meta-label">AUTOR</span>
                     <span class="meta-value" id="meta-autor"></span>
                  </li>
                  <li class="meta-item">
                     <span class="meta-label">UBICACIÓN / SECTOR</span>
                     <span class="meta-value" id="meta-ubicacion"></span>
                  </li>
                  <li class="meta-item">
                     <span class="meta-label">CÓDIGO</span>
                     <span class="meta-value" id="meta-codigo"></span>
                  </li>
                  <li class="meta-item">
                     <span class="meta-label">DIMENSIONES</span>
                     <span class="meta-value" id="meta-dimensiones"></span>
                  </li>
                  <li class="meta-item">
                     <span class="meta-label">ESTILO</span>
                     <span class="meta-value" id="meta-estilo"></span>
                  </li>
                  <li class="meta-item">
                     <span class="meta-label">CARACTERÍSTICAS</span>
                     <span class="meta-value" id="meta-caracteristicas"></span>
                  </li>
               </ul>

               <div class="artwork__description">
                  <h3>Reseña histórica</h3>
                  <div id="texto-resena"></div>
               </div>
            </div>
         </div>
      </div>
   </section>
</Layout>